<Window x:Class="ForeSITETestApp.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ForeSITE Alerting Report"
        Height="420"
        Width="720"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        Topmost="False">
    <Border CornerRadius="18" BorderBrush="#2A000000" BorderThickness="1" Background="#FFF7F7F7" Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Image Source="/ForeSITELogo.png" Width="520" Height="280" Stretch="Uniform" Margin="0,0,0,14"/>
                <TextBlock Text="ForeSITE Alerting Report"
                           FontSize="36"
                           FontWeight="SemiBold"
                           Foreground="#41454C"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,4">
                <ProgressBar Width="280" Height="8" IsIndeterminate="True" Foreground="#FFC62A" Background="#33A00028"/>
            </StackPanel>

            <TextBlock Grid.Row="1"
                       Text="ver. 1.0"
                       FontSize="12"
                       Foreground="#7A7F87"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Bottom"
                       Margin="0,0,4,2"/>
        </Grid>
    </Border>
</Window>
